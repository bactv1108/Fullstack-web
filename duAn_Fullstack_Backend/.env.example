DB_PASSWORD=your_database_password
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
JWT_SECRET=your_super_secret_jwt_key

# --- CẤU HÌNH DỮ LIỆU MỒI SEEDER ADMIN ---
SEED_ADMIN_PASSWORD=your_admin_password_here
SEED_ADMIN123_PASSWORD=your_admin123_password_here
SEED_USER_PASSWORD=your_default_user_password_here
SEED_ADMIN_EMAIL=your_admin_email_here
SEED_ADMIN123_EMAIL=your_admin_email_here

# ═══════════════════════════════════════════════════════════════
# FAL.AI — Tích hợp tạo Video AI Animation
# ═══════════════════════════════════════════════════════════════
# API Key lấy từ: https://fal.ai/dashboard/keys
FAL_API_KEY=your_fal_ai_api_key_here

# Endpoint model Fal.ai (mặc định: Kling Video v1.6 Pro)
# Có thể thay bằng: https://queue.fal.run/fal-ai/luma-dream-machine/...
FAL_MODEL_URL=https://queue.fal.run/fal-ai/kling-video/v1.6/pro/image-to-video

# URL Webhook tĩnh (dùng khi triển khai production, có domain cố định)
# Ở môi trường dev: để trống — DYNAMIC_WEBHOOK_URL từ Ngrok sẽ tự điền
FAL_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════
# NGROK — Auto-Tunnel cho Webhook Dev (chỉ dùng ở môi trường local)
# ═══════════════════════════════════════════════════════════════
# Bước 1: Đăng ký tài khoản miễn phí tại https://ngrok.com
# Bước 2: Lấy AuthToken tại https://dashboard.ngrok.com/get-started/your-authtoken
# Bước 3: Đặt ENABLE_TUNNEL=true và dán token vào bên dưới

# Bật/tắt auto-tunnel (chỉ hoạt động khi NODE_ENV !== 'production')
ENABLE_TUNNEL=false

# AuthToken Ngrok — BẮT BUỘC nếu ENABLE_TUNNEL=true
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# LƯU Ý: DYNAMIC_WEBHOOK_URL được server.js tự động sinh tại runtime.
# KHÔNG cần khai báo thủ công biến này vào .env.
# DYNAMIC_WEBHOOK_URL=  ← do hệ thống tự gán, không cần chỉnh